rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string &&
             data.email is string;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'description', 'amount', 'type', 'date']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['income', 'expense'] &&
             data.description is string && data.description.size() > 0 && data.description.size() < 100;
    }

    function isValidGoal(data) {
      return data.keys().hasAll(['userId', 'title', 'targetAmount', 'currentAmount', 'deadlineMonths']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.currentAmount is number &&
             data.deadlineMonths is number && data.deadlineMonths > 0;
    }

    function isValidGoalTransaction(data) {
      return data.keys().hasAll(['goalId', 'userId', 'amount', 'type', 'date']) &&
             data.userId == request.auth.uid &&
             data.goalId is string &&
             data.amount is number && data.amount > 0 &&
             data.type in ['deposit', 'withdraw'] &&
             data.date is string;
    }

    // Rules
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isDocOwner() && isValidTransaction(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /goals/{goalId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidGoal(request.resource.data);
      allow update: if isDocOwner() && isValidGoal(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /goal_transactions/{transactionId} {
      allow read: if isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidGoalTransaction(request.resource.data);
      allow delete: if isDocOwner();
    }
  }
}
